{
  "name": "dart",
  "displayName": "DART - Dependency Analysis and Resolution Toolkit",
  "description": "Intelligent assistant that detects missing dependencies, sets up virtual environments, and monitors project health for Python and Node.js.",
  "version": "2.0.0",
  "publisher": "DependencyAssistant",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DependencyAssistant/dart"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "dependency",
    "package manager",
    "pip",
    "npm",
    "virtual environment",
    "python",
    "nodejs",
    "missing module",
    "auto install"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dart.openPanel",
        "title": "DART: Open Panel"
      },
      {
        "command": "dart.refreshDependencies",
        "title": "DART: Refresh Dependency Scan"
      },
      {
        "command": "dart.createEnvironment",
        "title": "DART: Create Project Environment"
      },
      {
        "command": "dart.cleanupEnvironment",
        "title": "DART: Cleanup Unused Dependencies"
      },
      {
        "command": "dart.repairProject",
        "title": "DART: Repair Project Environment"
      },
      {
        "command": "dart.installDependency",
        "title": "DART: Install Dependency"
      },
      {
        "command": "dart.copyCommand",
        "title": "DART: Copy Install Command"
      },
      {
        "command": "dart.checkTerminal",
        "title": "DART: Check Terminal Output"
      },
      {
        "command": "dart.runEnvironmentDoctor",
        "title": "DART: Run Environment Doctor"
      },
      {
        "command": "dart.setupProject",
        "title": "DART: One-Click Project Setup"
      },
      {
        "command": "dart.syncDependencies",
        "title": "DART: Sync Dependencies"
      },
      {
        "command": "dart.exportEnvironment",
        "title": "DART: Export Environment Snapshot"
      },
      {
        "command": "dart.showDashboard",
        "title": "DART: Show Workspace Dashboard"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "dart.openPanel"
        },
        {
          "command": "dart.refreshDependencies"
        },
        {
          "command": "dart.createEnvironment"
        },
        {
          "command": "dart.cleanupEnvironment"
        },
        {
          "command": "dart.repairProject"
        },
        {
          "command": "dart.checkTerminal"
        },
        {
          "command": "dart.runEnvironmentDoctor"
        },
        {
          "command": "dart.setupProject"
        },
        {
          "command": "dart.syncDependencies"
        },
        {
          "command": "dart.exportEnvironment"
        },
        {
          "command": "dart.showDashboard"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dart",
          "title": "DART",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "dart": [
        {
          "id": "smartDependencyPanel",
          "name": "DART Assistant",
          "type": "webview",
          "icon": "media/icon.png"
        },
        {
          "id": "dartActivityPanel",
          "name": "Dependency Activity",
          "type": "webview",
          "visibility": "hidden",
          "icon": "media/icon.png"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "DART Settings",
      "properties": {
        "dart.autoInstall": {
          "type": "boolean",
          "default": true,
          "description": "Automatically install missing dependencies when detected."
        },
        "dart.confirmBeforeInstall": {
          "type": "boolean",
          "default": false,
          "description": "Ask for confirmation before installing a missing dependency."
        },
        "dart.autoCreateEnv": {
          "type": "boolean",
          "default": false,
          "description": "Automatically create and configure environments for supported projects."
        },
        "dart.autoActivateEnv": {
          "type": "boolean",
          "default": false,
          "description": "Automatically activate the virtual environment after creation."
        },
        "dart.autoReload": {
          "type": "boolean",
          "default": false,
          "description": "Automatically reload the workspace after environment setup."
        },
        "dart.autoFixDependencyIssues": {
          "type": "boolean",
          "default": false,
          "description": "Automatically attempt to fix detected dependency issues."
        },
        "dart.notifications": {
          "type": "string",
          "enum": [
            "minimal",
            "detailed",
            "silent"
          ],
          "default": "detailed",
          "description": "Notification verbosity level."
        },
        "dart.showSuccessNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications when packages are installed successfully."
        },
        "dart.showWarningNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show warning notifications for dependency issues."
        },
        "dart.showErrorNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show error notifications when operations fail."
        },
        "dart.showCommandExecutionNotifications": {
          "type": "boolean",
          "default": false,
          "description": "Show a notification each time a command is executed in the terminal."
        },
        "dart.healthCheck": {
          "type": "boolean",
          "default": true,
          "description": "Enable dependency health checks and dashboard updates."
        },
        "dart.scanOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Scan the workspace for dependency issues on startup."
        },
        "dart.scanOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Re-scan when a source file is saved."
        },
        "dart.scanOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Re-scan when a source file is opened."
        },
        "dart.scanDelayMs": {
          "type": "number",
          "default": 1200,
          "minimum": 300,
          "maximum": 10000,
          "description": "Debounce delay (ms) before scanning after editor changes."
        },
        "dart.safeMode": {
          "type": "boolean",
          "default": true,
          "description": "Block commands that appear unsafe or contain injection characters."
        },
        "dart.verifyPackagesBeforeInstall": {
          "type": "boolean",
          "default": true,
          "description": "Verify package exists in PyPI/npm registry before running install command."
        },
        "dart.languages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "python",
              "javascript",
              "typescript",
              "nodejs"
            ]
          },
          "default": [
            "python",
            "javascript"
          ],
          "description": "Languages DART should monitor."
        },
        "dart.statusBarEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show DART status in the VS Code status bar."
        },
        "dart.outputLogsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable DART log output channel."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --target=node18",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.19.10",
    "eslint": "^8.55.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "5.3.3"
  },
  "dependencies": {}
}
