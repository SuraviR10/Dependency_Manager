{
  "name": "dependify",
  "displayName": "Dependify – Smart Dependency Manager",
  "description": "Automatically detects missing dependencies, creates virtual environments, installs packages, and monitors project health for Python and Node.js projects.",
  "version": "0.2.1",
  "publisher": "DependencyAssistant",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DependencyAssistant/dependify"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "dependency",
    "package manager",
    "pip",
    "npm",
    "virtual environment",
    "python",
    "nodejs",
    "missing module",
    "auto install"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "smartDependencyAssistant.openPanel",
        "title": "Dependify: Open Panel"
      },
      {
        "command": "smartDependencyAssistant.refreshDependencies",
        "title": "Dependify: Refresh Dependency Scan"
      },
      {
        "command": "smartDependencyAssistant.createEnvironment",
        "title": "Dependify: Create Project Environment"
      },
      {
        "command": "smartDependencyAssistant.cleanupEnvironment",
        "title": "Dependify: Cleanup Unused Dependencies"
      },
      {
        "command": "smartDependencyAssistant.repairProject",
        "title": "Dependify: Repair Project Environment"
      },
      {
        "command": "smartDependencyAssistant.installDependency",
        "title": "Dependify: Install Dependency"
      },
      {
        "command": "smartDependencyAssistant.copyCommand",
        "title": "Dependify: Copy Install Command"
      },
      {
        "command": "smartDependencyAssistant.checkTerminal",
        "title": "Dependify: Check Terminal Output"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "smartDependencyAssistant.openPanel"
        },
        {
          "command": "smartDependencyAssistant.refreshDependencies"
        },
        {
          "command": "smartDependencyAssistant.createEnvironment"
        },
        {
          "command": "smartDependencyAssistant.cleanupEnvironment"
        },
        {
          "command": "smartDependencyAssistant.repairProject"
        },
        {
          "command": "smartDependencyAssistant.checkTerminal"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dependify",
          "title": "Dependify",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "dependify": [
        {
          "id": "smartDependencyPanel",
          "name": "Smart Dependency Assistant",
          "icon": "media/icon.png",
          "type": "webview"
        },
        {
          "id": "smartActivityPanel",
          "name": "Dependency Activity",
          "icon": "media/icon.png",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Dependify Settings",
      "properties": {
        "dependify.autoInstall": {
          "type": "boolean",
          "default": true,
          "description": "Automatically install missing dependencies when detected."
        },
        "dependify.confirmBeforeInstall": {
          "type": "boolean",
          "default": false,
          "description": "Ask for confirmation before installing a missing dependency."
        },
        "dependify.autoCreateEnv": {
          "type": "boolean",
          "default": false,
          "description": "Automatically create and configure environments for supported projects."
        },
        "dependify.autoActivateEnv": {
          "type": "boolean",
          "default": false,
          "description": "Automatically activate the virtual environment after creation."
        },
        "dependify.autoReload": {
          "type": "boolean",
          "default": false,
          "description": "Automatically reload the workspace after environment setup."
        },
        "dependify.autoFixDependencyIssues": {
          "type": "boolean",
          "default": false,
          "description": "Automatically attempt to fix detected dependency issues."
        },
        "dependify.notifications": {
          "type": "string",
          "enum": [
            "minimal",
            "detailed",
            "silent"
          ],
          "default": "detailed",
          "description": "Notification verbosity level."
        },
        "dependify.showSuccessNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications when packages are installed successfully."
        },
        "dependify.showWarningNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show warning notifications for dependency issues."
        },
        "dependify.showErrorNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show error notifications when operations fail."
        },
        "dependify.showCommandExecutionNotifications": {
          "type": "boolean",
          "default": false,
          "description": "Show a notification each time a command is executed in the terminal."
        },
        "dependify.healthCheck": {
          "type": "boolean",
          "default": true,
          "description": "Enable dependency health checks and dashboard updates."
        },
        "dependify.scanOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Scan the workspace for dependency issues on startup."
        },
        "dependify.scanOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Re-scan when a source file is saved."
        },
        "dependify.scanOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Re-scan when a source file is opened."
        },
        "dependify.scanDelayMs": {
          "type": "number",
          "default": 1200,
          "minimum": 300,
          "maximum": 10000,
          "description": "Debounce delay (ms) before scanning after editor changes."
        },
        "dependify.safeMode": {
          "type": "boolean",
          "default": true,
          "description": "Block commands that appear unsafe or contain injection characters."
        },
        "dependify.verifyPackagesBeforeInstall": {
          "type": "boolean",
          "default": true,
          "description": "Verify package exists in PyPI/npm registry before running install command."
        },
        "dependify.languages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "python",
              "javascript",
              "typescript",
              "nodejs"
            ]
          },
          "default": [
            "python",
            "javascript"
          ],
          "description": "Languages Dependify should monitor."
        },
        "dependify.statusBarEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Dependify status in the VS Code status bar."
        },
        "dependify.outputLogsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Dependify log output channel."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --target=node18",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.19.10",
    "eslint": "^8.55.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "5.3.3"
  },
  "dependencies": {}
}
