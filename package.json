{
  "name": "dartx",
  "displayName": "DARTX",
  "description": "DARTX automatically detects and resolves dependency issues before they slow down your development workflow.",
  "version": "1.2.0",
  "publisher": "DependencyAssistant",
  "author": "Suravi R",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SuraviR10/Dependency_Manager.git"
  },
  "bugs": {
    "url": "https://github.com/SuraviR10/Dependency_Manager/issues"
  },
  "homepage": "https://suravir10.github.io/Dependency_Manager/",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "dependency",
    "package manager",
    "pip",
    "npm",
    "virtual environment",
    "python",
    "nodejs",
    "missing module",
    "auto install"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dartx.openPanel",
        "title": "DARTX: Open Assistant Panel"
      },
      {
        "command": "dartx.refreshDependencies",
        "title": "DARTX: Refresh Dependency Scan"
      },
      {
        "command": "dartx.createEnvironment",
        "title": "DARTX: Create Project Environment"
      },
      {
        "command": "dartx.cleanupEnvironment",
        "title": "DARTX: Cleanup Unused Dependencies"
      },
      {
        "command": "dartx.repairProject",
        "title": "DARTX: Repair Project Environment"
      },
      {
        "command": "dartx.installDependency",
        "title": "DARTX: Install Dependency"
      },
      {
        "command": "dartx.copyCommand",
        "title": "DARTX: Copy Install Command"
      },
      {
        "command": "dartx.checkTerminal",
        "title": "DARTX: Check Terminal Output"
      },
      {
        "command": "dartx.runEnvironmentDoctor",
        "title": "DARTX: Run Environment Doctor"
      },
      {
        "command": "dartx.setupProject",
        "title": "DARTX: Clone & Run Setup"
      },
      {
        "command": "dartx.syncDependencies",
        "title": "DARTX: Sync Dependencies"
      },
      {
        "command": "dartx.exportEnvironment",
        "title": "DARTX: Export Environment Snapshot"
      },
      {
        "command": "dartx.showDashboard",
        "title": "DARTX: Show Workspace Dashboard"
      },
      {
        "command": "dartx.impactAnalysis",
        "title": "DARTX: Dependency Impact Analysis"
      },
      {
        "command": "dartx.upgradeAdvisor",
        "title": "DARTX: Smart Upgrade Advisor"
      },
      {
        "command": "dartx.knowledgeGraph",
        "title": "DARTX: Dependency Knowledge Graph"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "dartx.openPanel"
        },
        {
          "command": "dartx.setupProject"
        },
        {
          "command": "dartx.impactAnalysis"
        },
        {
          "command": "dartx.upgradeAdvisor"
        },
        {
          "command": "dartx.knowledgeGraph"
        },
        {
          "command": "dartx.showDashboard"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dartx",
          "title": "DARTX",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "dartx": [
        {
          "id": "smartDependencyPanel",
          "name": "DARTX: Dependency Issues",
          "type": "webview",
          "icon": "media/icon.svg"
        },
        {
          "id": "dartActivityPanel",
          "name": "DARTX: Activity Log",
          "type": "webview",
          "visibility": "hidden",
          "icon": "media/icon.svg"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "DARTX Settings",
      "properties": {
        "dartx.autoInstall": {
          "type": "boolean",
          "default": true,
          "description": "Automatically install missing dependencies when detected."
        },
        "dartx.confirmBeforeInstall": {
          "type": "boolean",
          "default": false,
          "description": "Ask for confirmation before installing a missing dependency."
        },
        "dartx.autoCreateEnv": {
          "type": "boolean",
          "default": false,
          "description": "Automatically create and configure environments for supported projects. Note: This may run tasks in your terminal on startup."
        },
        "dartx.autoActivateEnv": {
          "type": "boolean",
          "default": false,
          "description": "Automatically activate the virtual environment after creation."
        },
        "dartx.autoReload": {
          "type": "boolean",
          "default": false,
          "description": "Automatically reload the workspace after environment setup."
        },
        "dartx.autoFixDependencyIssues": {
          "type": "boolean",
          "default": false,
          "description": "Automatically attempt to fix detected dependency issues."
        },
        "dartx.notifications": {
          "type": "string",
          "enum": [
            "minimal",
            "detailed",
            "silent"
          ],
          "default": "detailed",
          "description": "Notification verbosity level."
        },
        "dartx.showSuccessNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications when packages are installed successfully."
        },
        "dartx.showWarningNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show warning notifications for dependency issues."
        },
        "dartx.showErrorNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show error notifications when operations fail."
        },
        "dartx.showCommandExecutionNotifications": {
          "type": "boolean",
          "default": false,
          "description": "Show a notification each time a command is executed in the terminal."
        },
        "dartx.healthCheck": {
          "type": "boolean",
          "default": true,
          "description": "Enable dependency health checks and dashboard updates on user action."
        },
        "dartx.scanOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Scan the workspace for dependency issues on startup."
        },
        "dartx.scanOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Re-scan when a source file is saved."
        },
        "dartx.scanOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Re-scan when a source file is opened."
        },
        "dartx.scanDelayMs": {
          "type": "number",
          "default": 1200,
          "minimum": 300,
          "maximum": 10000,
          "description": "Debounce delay (ms) before scanning after editor changes."
        },
        "dartx.safeMode": {
          "type": "boolean",
          "default": true,
          "description": "Block commands that appear unsafe or contain injection characters."
        },
        "dartx.verifyPackagesBeforeInstall": {
          "type": "boolean",
          "default": true,
          "description": "Verify package exists in PyPI/npm registry before running install command."
        },
        "dartx.languages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "python",
              "javascript",
              "typescript",
              "nodejs"
            ]
          },
          "default": [
            "python",
            "javascript"
          ],
          "description": "Languages DARTX should monitor."
        },
        "dartx.statusBarEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show DARTX status in the VS Code status bar."
        },
        "dartx.outputLogsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable DARTX log output channel."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --target=node18",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.19.10",
    "eslint": "^8.55.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "5.3.3"
  },
  "dependencies": {}
}
