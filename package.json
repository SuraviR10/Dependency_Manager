{
  "name": "smart-dependency-assistant",
  "displayName": "Smart Dependency Assistant",
  "description": "Identify and resolve dependency-related issues while coding. Monitor terminal errors, detect dependency problems, and suggest installation commands.",
  "version": "0.1.0",
  "publisher": "DependencyAssistant",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "dependency",
    "error",
    "module",
    "package",
    "pip",
    "npm"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:smartDependencyAssistant.openPanel",
    "onCommand:smartDependencyAssistant.refreshDependencies",
    "onCommand:smartDependencyAssistant.createEnvironment",
    "onCommand:smartDependencyAssistant.cleanupEnvironment",
    "onCommand:smartDependencyAssistant.repairProject"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "smartDependencyAssistant.openPanel",
        "title": "Open Smart Dependency Assistant"
      },
      {
        "command": "smartDependencyAssistant.refreshDependencies",
        "title": "Refresh Dependency Scan"
      },
      {
        "command": "smartDependencyAssistant.createEnvironment",
        "title": "Create Project Environment"
      },
      {
        "command": "smartDependencyAssistant.cleanupEnvironment",
        "title": "Cleanup Unused Dependencies"
      },
      {
        "command": "smartDependencyAssistant.repairProject",
        "title": "Repair Project Environment"
      },
      {
        "command": "smartDependencyAssistant.installDependency",
        "title": "Install Dependency"
      },
      {
        "command": "smartDependencyAssistant.copyCommand",
        "title": "Copy Install Command"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "smartDependencyPanel",
          "name": "Smart Dependency Assistant"
        }
      ]
    },
    "viewsContainers": {
      "explorer": [
        {
          "id": "smartDependencyAssistant",
          "title": "Smart Dependency",
          "icon": "media/icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --target=node18",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.19.10",
    "eslint": "^8.55.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "5.3.3"
  },
  "dependencies": {}
}
