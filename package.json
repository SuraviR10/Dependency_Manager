{
  "name": "dependify",
  "displayName": "Dependify",
  "description": "Dependify detects missing dependencies while coding and suggests safe install commands for Python and Node.js projects.",
  "version": "0.1.0",
  "publisher": "DependencyAssistant",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "dependency",
    "error",
    "module",
    "package",
    "pip",
    "npm"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "smartDependencyAssistant.openPanel",
        "title": "Open Smart Dependency Assistant"
      },
      {
        "command": "smartDependencyAssistant.refreshDependencies",
        "title": "Refresh Dependency Scan"
      },
      {
        "command": "smartDependencyAssistant.createEnvironment",
        "title": "Create Project Environment"
      },
      {
        "command": "smartDependencyAssistant.cleanupEnvironment",
        "title": "Cleanup Unused Dependencies"
      },
      {
        "command": "smartDependencyAssistant.repairProject",
        "title": "Repair Project Environment"
      },
      {
        "command": "smartDependencyAssistant.installDependency",
        "title": "Install Dependency"
      },
      {
        "command": "smartDependencyAssistant.copyCommand",
        "title": "Copy Install Command"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "smartDependencyPanel",
          "name": "Smart Dependency Assistant"
        },
        {
          "id": "smartActivityPanel",
          "name": "Dependency Activity"
        }
      ]
    },
    "viewsContainers": {
      "explorer": [
        {
          "id": "smartDependencyAssistant",
          "title": "Smart Dependency",
          "icon": "media/icon.svg"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Dependify Settings",
      "properties": {
        "dependify.autoInstall": {
          "type": "boolean",
          "default": false,
          "description": "Automatically install missing dependencies when detected."
        },
        "dependify.confirmBeforeInstall": {
          "type": "boolean",
          "default": true,
          "description": "Ask for confirmation before installing a missing dependency."
        },
        "dependify.languages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["python", "javascript", "nodejs"]
          },
          "default": ["python", "javascript"],
          "description": "Languages Dependify should monitor for missing dependencies."
        },
        "dependify.autoCreateEnv": {
          "type": "boolean",
          "default": false,
          "description": "Automatically create and configure environments for supported projects."
        },
        "dependify.autoReload": {
          "type": "boolean",
          "default": false,
          "description": "Automatically reload the workspace after environment setup."
        },
        "dependify.notifications": {
          "type": "string",
          "enum": ["minimal", "detailed", "silent"],
          "default": "detailed",
          "description": "Notification level for Dependify status updates."
        },
        "dependify.safeMode": {
          "type": "boolean",
          "default": true,
          "description": "Block commands that appear unsafe or invalid."
        },
        "dependify.healthCheck": {
          "type": "boolean",
          "default": true,
          "description": "Enable periodic dependency health checks and dashboard updates."
        },
        "dependify.scanDelayMs": {
          "type": "number",
          "default": 1200,
          "description": "Delay in milliseconds before scanning after editor changes."
        },
        "dependify.statusBarEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Dependify status in the VS Code status bar."
        },
        "dependify.outputLogsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Dependify log output in the Dependify Logs output channel."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --target=node18",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.19.10",
    "eslint": "^8.55.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "5.3.3"
  },
  "dependencies": {}
}
